# ==================================================
# Cherry Agent Landing Web - Environment Variables
# Copy this file to .env and fill in your values
# ==================================================

# Base URL for installer download links (e.g. your CDN or file hosting).
# Used to build download URLs for Mac/Windows installers.
# VITE_DOWNLOAD_BASE_URL=https://your-cdn.example.com

# Comma-separated list of trusted origins for managed download URLs returned
# by the API server. URLs not matching these origins will fall back to
# VITE_DOWNLOAD_BASE_URL. Example:
# VITE_TRUSTED_DOWNLOAD_ORIGINS=https://github.com/your-org/your-repo/releases/

# API server base URL (without trailing slash)
VITE_API_BASE_URL=http://localhost:3000
