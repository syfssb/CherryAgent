{
    "compilerOptions": {
        "strict": true,
        "target": "ESNext",
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "rootDir": "../..",
        "outDir": "../../dist-electron",
        "skipLibCheck": true,
        "incremental": true,
        "tsBuildInfoFile": "../../dist-electron/.tsbuildinfo",
        "paths": {
            "@cherry-agent/shared": ["../../packages/shared/src/index.ts"],
            "@cherry-agent/core": ["../../packages/core/src/index.ts"],
            "@cherry-agent/core/*": ["../../packages/core/src/*"]
        }
    },
    "include": [
        ".",
        "../../packages/shared/src",
        "../../packages/core/src"
    ],
    "exclude": [
        "**/__tests__/**",
        "**/*.test.ts",
        "**/*.spec.ts"
    ]
}
