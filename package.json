{
  "name": "cherry-agent",
  "private": true,
  "version": "1.0.30",
  "type": "module",
  "license": "Apache-2.0",
  "main": "dist-electron/src/electron/main.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/your-org/cherry-agent.git"
  },
  "scripts": {
    "rebuild": "npx electron-rebuild -f -w better-sqlite3",
    "predev": "lsof -ti:5173 | xargs kill -9 2>/dev/null; pkill -f electron 2>/dev/null || true",
    "dev": "bun run dev:react & bun run dev:electron",
    "dev:react": "vite",
    "dev:electron": "bun run transpile:electron && cross-env NODE_ENV=development ELECTRON_DISABLE_GPU=1 electron . --enable-logging --log-level=0",
    "build": "vite build",
    "build:desktop": "bun run transpile:electron && bun run build",
    "lint": "eslint .",
    "preview": "vite preview",
    "transpile:electron": "tsc --project src/electron/tsconfig.json && tsc-alias --project src/electron/tsconfig.json",
    "pack:mac-arm64": "bash ./scripts/pack-mac.sh arm64 zip",
    "pack:mac-x64": "bash ./scripts/pack-mac.sh x64 zip",
    "pack:mac-arm64:dmg": "bash ./scripts/pack-mac.sh arm64 dmg",
    "pack:mac-x64:dmg": "bash ./scripts/pack-mac.sh x64 dmg",
    "pack:win": "bash ./scripts/pack-win.sh",
    "pack:linux": "electron-builder --linux --x64 --publish never",
    "dist:mac-arm64": "bun run build:desktop && bun run pack:mac-arm64",
    "dist:mac-x64": "bun run build:desktop && bun run pack:mac-x64",
    "dist:mac-arm64:pack-only": "bun run pack:mac-arm64",
    "dist:mac-x64:pack-only": "bun run pack:mac-x64",
    "dist:mac-arm64:dmg": "bun run build:desktop && bun run pack:mac-arm64:dmg",
    "dist:mac-x64:dmg": "bun run build:desktop && bun run pack:mac-x64:dmg",
    "dist:win": "bun run build:desktop && bun run pack:win",
    "dist:linux": "bun run build:desktop && bun run pack:linux",
    "repair:node-modules": "bash ./scripts/repair-node-modules.sh",
    "prepare:update-feeds:mac": "bash ./scripts/prepare-mac-update-feeds.sh",
    "prepare:update-feeds:github": "bash ./scripts/prepare-github-update-urls.sh",
    "prepare:update-feeds:cos": "bash ./scripts/maintainer/prepare-cos-update-urls.sh",
    "deploy:installer:cos": "bash ./scripts/maintainer/deploy-installer-to-cos.sh",
    "deploy:installer:github": "bash ./scripts/deploy-installer-to-github.sh",
    "deploy:update-feed:github": "bash ./scripts/maintainer/deploy-update-feed-to-github-pages.sh",
    "release:patch:unsigned": "bash ./scripts/release-github-patch-unsigned.sh",
    "release:patch:signed": "bash ./scripts/release-github-patch-signed.sh",
    "test": "vitest run",
    "test:unit": "vitest run --project unit --project api-unit",
    "test:integration": "vitest run --project integration --project api-integration",
    "test:all": "vitest run --project unit --project api-unit && vitest run --project integration --project api-integration",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --coverage",
    "test:smoke": "playwright test --config=playwright.smoke.config.ts",
    "test:e2e": "playwright test --project=electron",
    "test:watch": "vitest --project unit --project api-unit",
    "prepare:python": "bash scripts/download-python.sh all",
    "prepare:python:packages": "bash scripts/preinstall-python-packages.sh all",
    "release:prepare-python": "bash scripts/download-python.sh all && bash scripts/preinstall-python-packages.sh all"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.6",
    "@openai/codex-sdk": "./openai-codex-sdk-0.106.0.tgz",
    "@radix-ui/react-context-menu": "^2.2.16",
    "better-sqlite3": "^12.6.0",
    "docx": "^9.5.0",
    "dotenv": "^17.2.3",
    "electron-log": "^5.4.3",
    "electron-updater": "^6.7.3",
    "exceljs": "^4.4.0",
    "os-utils": "^0.0.14",
    "p-queue": "^9.1.0",
    "pdf-lib": "^1.17.1",
    "pptxgenjs": "^4.0.1",
    "win-ca": "^3.5.1"
  },
  "devDependencies": {
    "@clerk/clerk-js": "^5.125.0",
    "@eslint/js": "^9.39.2",
    "@playwright/test": "^1.58.2",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/os-utils": "^0.0.4",
    "@types/pg": "^8.16.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.0.18",
    "babel-plugin-react-compiler": "^1.0.0",
    "bcryptjs": "^2.4.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "driver.js": "^1.4.0",
    "electron": "36.9.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.26",
    "globals": "^17.0.0",
    "highlight.js": "^11.11.1",
    "i18next": "^25.8.0",
    "i18next-browser-languagedetector": "^8.2.0",
    "jsdom": "^24.0.0",
    "jsonwebtoken": "^9.0.3",
    "lucide-react": "^0.575.0",
    "pg": "^8.18.0",
    "react": "^19.2.3",
    "react-dom": "^19.2.3",
    "react-i18next": "^16.5.4",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.4.0",
    "tailwindcss": "^4.1.18",
    "tsc-alias": "^1.8.16",
    "typescript": "5.7.2",
    "typescript-eslint": "^8.52.0",
    "vite": "^7.3.1",
    "vite-tsconfig-paths": "^6.0.3",
    "vitest": "^4.0.18",
    "wouter": "^3.9.0",
    "zustand": "^5.0.10"
  },
  "patchedDependencies": {
    "@anthropic-ai/claude-agent-sdk@0.2.6": "patches/@anthropic-ai%2Fclaude-agent-sdk@0.2.6.patch"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "electron",
      "better-sqlite3",
      "esbuild"
    ]
  }
}
