# ============================================================
# docker compose 环境变量（控制容器端口和数据库密码）
# 复制为 .env：cp .env.example .env
# ============================================================

# PostgreSQL 密码（api-server/.env 中的 DATABASE_URL 会自动使用此密码）
POSTGRES_PASSWORD=changeme_in_production

# 对外暴露的端口
API_PORT=3000
LANDING_PORT=8080
