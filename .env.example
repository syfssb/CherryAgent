# API backend URL (required for auth/billing features)
# Leave empty for local-only use — the app works without a backend
CHERRY_API_URL=

# Vite frontend API URL (used by renderer process)
VITE_API_BASE_URL=http://localhost:3000/api

# Update feed URL for auto-update (leave empty to disable)
DESKTOP_UPDATE_BASE_URL=

# Additional OAuth callback origins, comma-separated (optional)
# CHERRY_OAUTH_ORIGINS=https://auth.example.com

# Additional allowed payment domains, comma-separated (optional)
# CHERRY_ALLOWED_PAYMENT_DOMAINS=your-domain.com
