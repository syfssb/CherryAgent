# ==================================================
# Cherry Agent API Server - Environment Variables
# Copy this file to .env and fill in your values
# ==================================================

# --- Server ---
NODE_ENV=development
PORT=3000
API_BASE_URL=http://localhost:3000
FRONTEND_URL=http://127.0.0.1:5173
LANDING_URL=http://localhost:3002

# --- Database (required) ---
DATABASE_URL=postgres://user:password@localhost:5432/cherry_agent
# DB_POOL_MIN=0
# DB_POOL_MAX=10
# DB_POOL_IDLE_TIMEOUT_MS=30000
# DB_POOL_CONNECTION_TIMEOUT_MS=5000

# --- JWT (required) ---
JWT_SECRET=your-jwt-secret-at-least-32-characters-long!!
# JWT_REFRESH_SECRET=
# JWT_EXPIRES_IN=30d
# JWT_REFRESH_EXPIRES_IN=30d
# ADMIN_JWT_EXPIRES_IN=30d

# --- Encryption (required, 64-char hex) ---
API_KEY_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# --- AI Providers (at least one required) ---
# Anthropic
ANTHROPIC_API_KEY=sk-ant-xxx
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_PROVIDER_NAME=

# OpenAI
# OPENAI_API_KEY=sk-xxx
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_PROVIDER_NAME=

# Google AI
# GOOGLE_AI_API_KEY=

# Custom Proxy (e.g. OpenRouter, one-api, etc.)
# PROXY_API_KEY=
# PROXY_BASE_URL=
# PROXY_COST_MULTIPLIER=1.0
# PROXY_MODELS=model-a,model-b
# PROXY_PROVIDER_NAME=

# --- Stripe Payment (optional) ---
# STRIPE_SECRET_KEY=sk_test_xxx
# STRIPE_WEBHOOK_SECRET=whsec_xxx
# STRIPE_PUBLISHABLE_KEY=pk_test_xxx

# --- XunhuPay / HuPiJiao (optional, China payments) ---
# XUNHUPAY_APPID=
# XUNHUPAY_APPSECRET=
# XUNHUPAY_GATEWAY_URL=https://api.xunhupay.com/payment/do.html
# XUNHUPAY_NOTIFY_URL=

# --- Google OAuth (optional) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_OAUTH_REDIRECT_URI=http://localhost:3000/auth/google/callback

# --- Rate Limiting ---
# RATE_LIMIT_WINDOW_MS=60000
# RATE_LIMIT_MAX_REQUESTS=100

# --- Logging ---
# LOG_LEVEL=info
# LOG_FORMAT=combined

# --- CORS ---
# CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# --- Alerts (optional) ---
# SLACK_WEBHOOK_URL=
# ALERT_EMAIL_RECIPIENTS=admin@example.com

# --- Network Proxy (for accessing Google APIs from China) ---
# HTTPS_PROXY=http://127.0.0.1:7890
